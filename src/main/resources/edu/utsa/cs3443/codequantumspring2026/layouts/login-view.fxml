<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="438.0" prefWidth="579.0" spacing="20.0" style="-fx-background-color: #D3D3D3;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.utsa.cs3443.codequantumspring2026.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/F1-Logo-PNG-HD.png" />
         </image>
      </ImageView>
      <TextField fx:id="usernameTextField" promptText="Username" style="-fx-border-color: #000000;">
         <effect>
            <DropShadow />
         </effect>
      </TextField>
      <TextField fx:id="passwordTextField" promptText="Password" style="-fx-border-color: #000000;">
         <effect>
            <DropShadow />
         </effect>
      </TextField>
      <Button mnemonicParsing="false" onAction="#onLoginButtonClicked" text="Login">
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Button mnemonicParsing="false" onAction="#onSignUpButtonClicked" text="Sign Up" visible="false">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Label fx:id="errorLabel" />
   </children>
</VBox>
